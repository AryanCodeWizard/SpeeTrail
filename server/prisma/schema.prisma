generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  memberships     GroupMembership[]
  expensesPaid    Expense[]         @relation("PaidBy")
  expenseSplits   ExpenseSplit[]
  settlementsPaid Settlement[]      @relation("SettlementPaidBy")
  settlementsRcvd Settlement[]      @relation("SettlementPaidTo")
  groupsCreated   Group[]
  importSessions  ImportSession[]
  invitesSent     GroupInvite[]

  @@map("users")
}

model Group {
  id        String   @id @default(uuid())
  name      String
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator        User              @relation(fields: [createdBy], references: [id])
  memberships    GroupMembership[]
  expenses       Expense[]
  settlements    Settlement[]
  importSessions ImportSession[]
  invites        GroupInvite[]

  @@map("groups")
}

model GroupMembership {
  id       String    @id @default(uuid())
  groupId  String    @map("group_id")
  userId   String    @map("user_id")
  role     String    @default("member")
  joinedAt DateTime  @map("joined_at")
  leftAt   DateTime? @map("left_at")

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("group_memberships")
}

model Expense {
  id          String @id @default(uuid())
  groupId     String @map("group_id")
  paidBy      String @map("paid_by")
  description String

  amountOriginal Float  @map("amount_original")
  currency       String @default("INR")
  amountInr      Float  @map("amount_inr")
  fxRate         Float  @default(1) @map("fx_rate")

  splitType    String   @map("split_type")
  expenseDate  DateTime @map("expense_date")
  isSettlement Boolean  @default(false) @map("is_settlement")
  importId     String?  @map("import_id")
  createdAt    DateTime @default(now()) @map("created_at")

  group         Group          @relation(fields: [groupId], references: [id])
  payer         User           @relation("PaidBy", fields: [paidBy], references: [id])
  splits        ExpenseSplit[]
  importSession ImportSession? @relation(fields: [importId], references: [id])

  @@map("expenses")
}

model ExpenseSplit {
  id        String @id @default(uuid())
  expenseId String @map("expense_id")
  userId    String @map("user_id")

  shareAmount  Float  @map("share_amount")
  sharePercent Float? @map("share_percent")
  shareUnits   Float? @map("share_units")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("expense_splits")
}

model Settlement {
  id      String @id @default(uuid())
  groupId String @map("group_id")
  paidBy  String @map("paid_by")
  paidTo  String @map("paid_to")

  amount Float

  settledOn DateTime @map("settled_on")
  createdAt DateTime @default(now()) @map("created_at")

  group    Group @relation(fields: [groupId], references: [id])
  payer    User  @relation("SettlementPaidBy", fields: [paidBy], references: [id])
  receiver User  @relation("SettlementPaidTo", fields: [paidTo], references: [id])

  @@map("settlements")
}

model ImportSession {
  id            String    @id @default(uuid())
  groupId       String    @map("group_id")
  initiatedBy   String    @map("initiated_by")
  status        String    @default("pending_review")
  anomalyReport Json?     @map("anomaly_report")
  createdAt     DateTime  @default(now()) @map("created_at")
  approvedAt    DateTime? @map("approved_at")

  group     Group       @relation(fields: [groupId], references: [id])
  initiator User        @relation(fields: [initiatedBy], references: [id])
  rows      ImportRow[]
  expenses  Expense[]

  @@map("import_sessions")
}

model ImportRow {
  id            String  @id @default(uuid())
  importId      String  @map("import_id")
  rowNumber     Int     @map("row_number")
  rawData       Json    @map("raw_data")
  status        String
  anomalyType   String? @map("anomaly_type")
  anomalyDetail String? @map("anomaly_detail")
  actionTaken   String? @map("action_taken")

  importSession ImportSession @relation(fields: [importId], references: [id])

  @@map("import_rows")
}

model GroupInvite {
  id        String @id @default(uuid())
  groupId   String @map("group_id")
  email     String
  token     String @unique
  role      String @default("member")
  invitedBy String @map("invited_by")

  status     String    @default("pending")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")

  createdAt DateTime @default(now()) @map("created_at")

  group   Group @relation(fields: [groupId], references: [id])
  inviter User  @relation(fields: [invitedBy], references: [id])

  @@map("group_invites")
}
